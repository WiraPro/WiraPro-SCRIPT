-- panelStartX/Y menyimpan pixel offset posisi panel saat drag dimulai
-- (sudah dikonversi dari AbsolutePosition agar tidak ada loncatan)
local panelStartX, panelStartY = 0, 0
local dragStartX, dragStartY = 0, 0

DragBtn.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
        draggingPanel = true
        local pos = UserInputService:GetMouseLocation()
        dragStartX, dragStartY = pos.X, pos.Y
        -- Simpan posisi absolut panel sekarang sebagai titik awal
        -- AbsolutePosition sudah valid karena panel sudah render
        panelStartX = MainPanel.AbsolutePosition.X
        panelStartY = MainPanel.AbsolutePosition.Y
        -- Langsung convert panel ke pure pixel offset supaya drag konsisten
        MainPanel.Position = UDim2.new(0, panelStartX, 0, panelStartY)
    end
end)

DragBtn.InputChanged:Connect(function(inp)
    if not draggingPanel then return end
    if inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch then
        local pos = UserInputService:GetMouseLocation()
        local newX = panelStartX + (pos.X - dragStartX)
        local newY = panelStartY + (pos.Y - dragStartY)
        MainPanel.Position = UDim2.new(0, newX, 0, newY)
    end
end)

DragBtn.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
        draggingPanel = false
    end
end)

UserInputService.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingPanel = false
    end
end)

