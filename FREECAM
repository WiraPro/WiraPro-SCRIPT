-- UI PERSISTENCE PROTECTION
-- Mencegah UI hilang ketika game menggunakan
-- fitur "Hide UI" / CoreGui visibility toggle
-- ══════════════════════════════════════════
local function enforceUIVisibility()
    -- Pastikan ScreenGui selalu visible & tidak terhapus
    if not ScreenGui or not ScreenGui.Parent then
        -- Buat ulang jika terhapus
        ScreenGui=Instance.new("ScreenGui")
        ScreenGui.Name="WiraProFreecam"; ScreenGui.ResetOnSpawn=false
        ScreenGui.DisplayOrder=999; ScreenGui.ZIndexBehavior=Enum.ZIndexBehavior.Sibling
                ScreenGui.Parent=PlayerGui
    end
    -- Paksa selalu enabled & visible
    ScreenGui.Enabled=true
end

-- Monitor setiap perubahan pada ScreenGui (Enabled, Parent, dll)
ScreenGui:GetPropertyChangedSignal("Enabled"):Connect(function()
    if not ScreenGui.Enabled then
        task.defer(function() ScreenGui.Enabled=true end)
    end
end)

ScreenGui:GetPropertyChangedSignal("Parent"):Connect(function()
    if ScreenGui.Parent~=PlayerGui then
        task.defer(function()
            pcall(function() ScreenGui.Parent=PlayerGui end)
        end)
    end
end)

-- Monitor PlayerGui: jika ada script yang destroy ScreenGui milik kita
PlayerGui.ChildRemoved:Connect(function(child)
    if child.Name=="WiraProFreecam" then
        task.defer(enforceUIVisibility)
    end
end)

-- Periodically enforce tiap 1 detik sebagai fallback
task.spawn(function()
    while true do
        task.wait(1)
        pcall(enforceUIVisibility)
    end
end)

-- Proteksi tambahan: monitor semua descendants PlayerGui yang mencoba
-- mengubah visibility seluruh UI (teknik umum "Hide All UI")
PlayerGui.DescendantAdded:Connect(function(obj)
    -- Cegah script lain menghide ScreenGui kita
    if obj:IsA("LocalScript") or obj:IsA("Script") then
        task.defer(function()
            if ScreenGui then
                pcall(function() ScreenGui.Enabled=true end)
            end
        end)
    end
end)

