-- UI HIT DETECTION
local function overPanel(pos)
    local pp=MainPanel.AbsolutePosition; local ps=MainPanel.AbsoluteSize
    return pos.X>=pp.X and pos.X<=pp.X+ps.X and pos.Y>=pp.Y and pos.Y<=pp.Y+ps.Y
end

