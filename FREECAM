local rotating=false; local lastMouse=Vector2.new(0,0)
UserInputService.InputBegan:Connect(function(inp,gpe)
    if not freecamActive or gpe or draggingPanel or mode~="free" then return end
    if inp.UserInputType==Enum.UserInputType.MouseButton2 then
        if overPanel(Vector2.new(inp.Position.X,inp.Position.Y)) then return end
        rotating=true; lastMouse=Vector2.new(inp.Position.X,inp.Position.Y)
    end
end)
UserInputService.InputEnded:Connect(function(inp)
    if inp.UserInputType==Enum.UserInputType.MouseButton2 then rotating=false end
end)
UserInputService.InputChanged:Connect(function(inp)
    if not freecamActive or draggingPanel or mode~="free" then return end
    if rotating and inp.UserInputType==Enum.UserInputType.MouseMovement then
        local d=Vector2.new(inp.Position.X-lastMouse.X,inp.Position.Y-lastMouse.Y)
        lastMouse=Vector2.new(inp.Position.X,inp.Position.Y)
        yaw=yaw-d.X*CFG.RotateSpeed
        pitch=math.clamp(pitch-d.Y*CFG.RotateSpeed,-math.pi/2+0.05,math.pi/2-0.05)
    end
end)

-- MOBILE TOUCH
local uiTouches={}
UserInputService.TouchStarted:Connect(function(t,gpe)
    if not freecamActive or mode~="free" then return end
    local pos=t.Position
    if overPanel(Vector2.new(pos.X,pos.Y)) or gpe or draggingPanel then uiTouches[t]=true; return end
    if pos.X<Camera.ViewportSize.X/2 then
        if not leftActive then leftActive=true; leftId=t; leftStart=Vector2.new(pos.X,pos.Y); leftCur=leftStart end
    else
        if not rightActive then rightActive=true; rightId=t; lastRight=Vector2.new(pos.X,pos.Y) end
    end
end)
UserInputService.TouchMoved:Connect(function(t,gpe)
    if not freecamActive or uiTouches[t] or mode~="free" then return end
    if t==leftId then leftCur=Vector2.new(t.Position.X,t.Position.Y)
    elseif t==rightId then
        local cur=Vector2.new(t.Position.X,t.Position.Y); local d=cur-lastRight; lastRight=cur
        yaw=yaw-d.X*CFG.RotateSpeed*1.5
        pitch=math.clamp(pitch-d.Y*CFG.RotateSpeed*1.5,-math.pi/2+0.05,math.pi/2-0.05)
    end
end)
UserInputService.TouchEnded:Connect(function(t,gpe)
    if uiTouches[t] then uiTouches[t]=nil; return end
    if t==leftId  then leftActive=false; leftId=nil; leftCur=leftStart end
    if t==rightId then rightActive=false; rightId=nil end
end)

