dragHandle.AutoButtonColor=false; dragHandle.ZIndex=13; dragHandle.Parent=titleBar

local pdx,pdy,idx,idy = 0,0,0,0

dragHandle.InputBegan:Connect(function(inp)
    if inp.UserInputType==Enum.UserInputType.MouseButton1
    or inp.UserInputType==Enum.UserInputType.Touch then
        dragging=true
        pdx=panel.AbsolutePosition.X; pdy=panel.AbsolutePosition.Y
        panel.Position=UDim2.new(0,pdx,0,pdy)
        local mp=UserInputService:GetMouseLocation()
        idx=mp.X; idy=mp.Y
    end
end)
dragHandle.InputChanged:Connect(function(inp)
    if not dragging then return end
    if inp.UserInputType==Enum.UserInputType.MouseMovement
    or inp.UserInputType==Enum.UserInputType.Touch then
        local mp=UserInputService:GetMouseLocation()
        panel.Position=UDim2.new(0,pdx+(mp.X-idx),0,pdy+(mp.Y-idy))
    end
end)
dragHandle.InputEnded:Connect(function(inp)
    if inp.UserInputType==Enum.UserInputType.MouseButton1
    or inp.UserInputType==Enum.UserInputType.Touch then dragging=false end
end)
UserInputService.InputEnded:Connect(function(inp)
    if inp.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
end)

