-- HELPER: frame glass transparan gelap
-- ══════════════════════════════════════════
local function makeGlass(parent, bgCol, bgAlpha, strokeCol, strokeAlpha, radius)
    local f = Instance.new("Frame")
    f.BackgroundColor3       = bgCol or C.Glass
    f.BackgroundTransparency = bgAlpha or 0.45
    f.BorderSizePixel        = 0
    f.Parent                 = parent
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, radius or 12)
    local s = Instance.new("UIStroke", f)
    s.Color        = strokeCol   or C.Accent
    s.Thickness    = 1.5
    s.Transparency = strokeAlpha or 0.55
    return f, s
end

