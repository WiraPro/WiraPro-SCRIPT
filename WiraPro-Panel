-- HELPER: blok slider
-- ══════════════════════════════════════════
local function makeSlider(parent, yTop, labelText, fillCol, minV, maxV, defV)
    local lbl = Instance.new("TextLabel")
    lbl.Size=UDim2.new(0,160,0,13); lbl.Position=UDim2.new(0,10,0,yTop)
    lbl.BackgroundTransparency=1; lbl.TextColor3=C.TextDim
    lbl.TextSize=9; lbl.Font=Enum.Font.GothamBold
    lbl.TextXAlignment=Enum.TextXAlignment.Left
    lbl.Text=labelText.." "..defV; lbl.ZIndex=5; lbl.Parent=parent

    local minL = Instance.new("TextLabel")
    minL.Size=UDim2.new(0,22,0,13); minL.Position=UDim2.new(0,10,0,yTop+14)
    minL.BackgroundTransparency=1; minL.Text=tostring(minV)
    minL.TextColor3=C.TextDim; minL.TextSize=8; minL.Font=Enum.Font.Gotham
    minL.TextXAlignment=Enum.TextXAlignment.Left; minL.ZIndex=5; minL.Parent=parent

    local maxL = Instance.new("TextLabel")
    maxL.Size=UDim2.new(0,30,0,13); maxL.Position=UDim2.new(1,-40,0,yTop+14)
    maxL.BackgroundTransparency=1; maxL.Text=tostring(maxV)
    maxL.TextColor3=C.TextDim; maxL.TextSize=8; maxL.Font=Enum.Font.Gotham
    maxL.TextXAlignment=Enum.TextXAlignment.Right; maxL.ZIndex=5; maxL.Parent=parent

    local track = Instance.new("Frame")
    track.Size=UDim2.new(1,-20,0,5); track.Position=UDim2.new(0,10,0,yTop+14)
    track.BackgroundColor3=C.SliderBg; track.BackgroundTransparency=0.30
    track.BorderSizePixel=0; track.ZIndex=5; track.Parent=parent
    Instance.new("UICorner",track).CornerRadius=UDim.new(1,0)
    local tStk=Instance.new("UIStroke",track)
    tStk.Color=fillCol; tStk.Thickness=1.0; tStk.Transparency=0.62

    local ratio0 = (defV-minV)/(maxV-minV)

    local fill = Instance.new("Frame")
    fill.Size=UDim2.new(ratio0,0,1,0)
    fill.BackgroundColor3=fillCol; fill.BackgroundTransparency=0.18
    fill.BorderSizePixel=0; fill.ZIndex=6; fill.Parent=track
    Instance.new("UICorner",fill).CornerRadius=UDim.new(1,0)

    local kn = Instance.new("Frame")
    kn.Size=UDim2.new(0,14,0,14); kn.Position=UDim2.new(ratio0,-7,0.5,-7)
    kn.BackgroundColor3=C.Knob; kn.BackgroundTransparency=0.05
    kn.BorderSizePixel=0; kn.ZIndex=7; kn.Parent=track
    Instance.new("UICorner",kn).CornerRadius=UDim.new(1,0)
    local kStk=Instance.new("UIStroke",kn)
    kStk.Color=fillCol; kStk.Thickness=1.8; kStk.Transparency=0.22

    local kShine=Instance.new("Frame")
    kShine.Size=UDim2.new(0.5,0,0,2); kShine.Position=UDim2.new(0.15,0,0,2)
    kShine.BackgroundColor3=Color3.fromRGB(255,255,255)
    kShine.BackgroundTransparency=0.35; kShine.BorderSizePixel=0
    kShine.ZIndex=8; kShine.Parent=kn
    Instance.new("UICorner",kShine).CornerRadius=UDim.new(1,0)

    return lbl, track, fill, kn
end

