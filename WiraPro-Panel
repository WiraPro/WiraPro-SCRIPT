-- ══════════════════════════════════════════
-- HOTKEYS
-- ══════════════════════════════════════════
UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end
    local k=inp.KeyCode
    if     k==KEY_FLY   then if isFlying      then disableFly()         else enableFly()         end
    elseif k==KEY_NC    then if isNoclip      then disableNoclip()       else enableNoclip()      end
    elseif k==KEY_ZFD   then if isZFD         then disableZFD()          else enableZFD()         end
    elseif k==KEY_IJ    then if isInfJump     then disableInfJump()      else enableInfJump()     end
    elseif k==KEY_RUN   then if isSpeedRun    then disableSpeedRun()     else enableSpeedRun()    end
    elseif k==KEY_ESP   then if isESP         then disableESP()          else enableESP()         end
    elseif k==KEY_FB    then if isFullbright  then disableFullbright()   else enableFullbright()  end  -- ← NEW
    elseif k==KEY_RESET then resetAll()
    end
end)

-- ══════════════════════════════════════════
-- FLIGHT LOOP
-- ══════════════════════════════════════════
RunService.RenderStepped:Connect(function()
    if not isFlying or not bVelocity or not bGyro then return end
    local char=player.Character; if not char then return end
    local root=char:FindFirstChild("HumanoidRootPart")
    local hum=char:FindFirstChildOfClass("Humanoid")
    if not root or not hum then return end

    local camCF   = workspace.CurrentCamera.CFrame
    local moveDir = Vector3.zero
    local md      = hum.MoveDirection
    local camLook  = Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z)
    local camRight = Vector3.new(camCF.RightVector.X, 0, camCF.RightVector.Z)
    if camLook.Magnitude  >0 then camLook=camLook.Unit   end
    if camRight.Magnitude >0 then camRight=camRight.Unit end

    local aFwd   = (md.Magnitude>0.1) and md:Dot(camLook)  or 0
    local aRight = (md.Magnitude>0.1) and md:Dot(camRight) or 0
    local kFwd   = (UserInputService:IsKeyDown(Enum.KeyCode.W) and 1 or 0)
                 - (UserInputService:IsKeyDown(Enum.KeyCode.S) and 1 or 0)
    local kRight = (UserInputService:IsKeyDown(Enum.KeyCode.D) and 1 or 0)
                 - (UserInputService:IsKeyDown(Enum.KeyCode.A) and 1 or 0)
    local fFwd   = math.abs(aFwd)>math.abs(kFwd)    and aFwd   or kFwd
    local fRight = math.abs(aRight)>math.abs(kRight) and aRight or kRight

    if math.abs(fFwd)  >0.05 then moveDir=moveDir+camCF.LookVector*fFwd   end
    if math.abs(fRight)>0.05 then moveDir=moveDir+camRight*fRight          end
    if moveDir.Magnitude>0   then moveDir=moveDir.Unit                      end

    bVelocity.Velocity=moveDir*flySpeed
    bGyro.CFrame=camCF
end)

-- ══════════════════════════════════════════
-- RESET SAAT RESPAWN
-- ══════════════════════════════════════════
player.CharacterAdded:Connect(function()
    isFlying=false; bVelocity=nil; bGyro=nil
    updateUI_Flying(false)

    if noclipConn then noclipConn:Disconnect(); noclipConn=nil end
    isNoclip=false; updateUI_Noclip(false)

    if zfdConn then zfdConn:Disconnect(); zfdConn=nil end
    local _isZFD=isZFD; isZFD=false
    if _isZFD then task.wait(0.5); enableZFD() end

    if ijConn then ijConn:Disconnect(); ijConn=nil end
    local _isIJ=isInfJump; isInfJump=false
    if _isIJ then task.wait(0.3); enableInfJump() end

    local _isRun=isSpeedRun; isSpeedRun=false
    if _isRun then
        task.wait(0.3)
        local char=player.Character
        if char then
            char:WaitForChild("Humanoid").WalkSpeed=runSpeed
            isSpeedRun=true
        end
    end

    -- Fullbright tidak reset saat respawn — Lighting tetap terjaga
    -- (Lighting tidak terikat ke karakter, jadi tidak perlu reconnect)
end)

