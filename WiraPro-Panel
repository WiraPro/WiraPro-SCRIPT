-- ENABLE / DISABLE — FULLBRIGHT           ← NEW
-- ══════════════════════════════════════════
local function enableFullbright()
    if isFullbright then return end; isFullbright = true

    -- Simpan nilai Lighting asli
    origAmbient        = Lighting.Ambient
    origOutdoorAmbient = Lighting.OutdoorAmbient
    origBrightness     = Lighting.Brightness
    origFogEnd         = Lighting.FogEnd
    origGlobalShadows  = Lighting.GlobalShadows

    -- Terapkan Fullbright
    Lighting.Ambient        = Color3.fromRGB(255, 255, 255)
    Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
    Lighting.Brightness     = 2
    Lighting.FogEnd         = 1e6   -- hapus kabut
    Lighting.GlobalShadows  = false

    updateUI_FB(true)
end

local function disableFullbright()
    if not isFullbright then return end; isFullbright = false

    -- Pulihkan nilai Lighting asli
    if origAmbient then
        Lighting.Ambient        = origAmbient
        Lighting.OutdoorAmbient = origOutdoorAmbient
        Lighting.Brightness     = origBrightness
        Lighting.FogEnd         = origFogEnd
        Lighting.GlobalShadows  = origGlobalShadows
    end

    updateUI_FB(false)
end

-- ══════════════════════════════════════════
-- ENABLE / DISABLE — FLY
-- ══════════════════════════════════════════
local function enableFly()
    local char=player.Character; if not char then return end
    local hum=char:FindFirstChildOfClass("Humanoid")
    local root=char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end

    isFlying=true; hum.PlatformStand=true

    bVelocity=Instance.new("BodyVelocity")
    bVelocity.Velocity=Vector3.zero
    bVelocity.MaxForce=Vector3.new(1e5,1e5,1e5)
    bVelocity.Parent=root

    bGyro=Instance.new("BodyGyro")
    bGyro.MaxTorque=Vector3.new(1e5,1e5,1e5)
    bGyro.D=100; bGyro.Parent=root

    updateUI_Flying(true)
end

local function disableFly()
    local char=player.Character
    if char then
        local hum=char:FindFirstChildOfClass("Humanoid")
        if hum then hum.PlatformStand=false end
    end
    isFlying=false
    if bVelocity then bVelocity:Destroy(); bVelocity=nil end
    if bGyro     then bGyro:Destroy();     bGyro=nil     end
    updateUI_Flying(false)
end

-- ══════════════════════════════════════════
-- ENABLE / DISABLE — NOCLIP
-- ══════════════════════════════════════════
local function enableNoclip()
    if isNoclip then return end; isNoclip=true
    noclipConn=RunService.Stepped:Connect(function()
        local char=player.Character; if not char then return end
        for _,p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide=false end
        end
        local r=char:FindFirstChild("HumanoidRootPart")
        if r then r.CanCollide=false end
    end)
    updateUI_Noclip(true)
end

local function disableNoclip()
    if not isNoclip then return end; isNoclip=false
    if noclipConn then noclipConn:Disconnect(); noclipConn=nil end
    local char=player.Character
    if char then
        for _,p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide=true end
        end
    end
    updateUI_Noclip(false)
end

-- ══════════════════════════════════════════
-- ENABLE / DISABLE — ZERO FALL DAMAGE
-- ══════════════════════════════════════════
local function enableZFD()
    if isZFD then return end; isZFD=true
    zfdConn=RunService.Heartbeat:Connect(function()
        local char=player.Character; if not char then return end
        local hum=char:FindFirstChildOfClass("Humanoid")
        local root=char:FindFirstChild("HumanoidRootPart")
        if not hum or not root then return end
        if root.Velocity.Y < -50 then
            hum:ChangeState(Enum.HumanoidStateType.Landed)
            root.Velocity=Vector3.new(root.Velocity.X,-10,root.Velocity.Z)
            if hum.Health < hum.MaxHealth then hum.Health=hum.MaxHealth end
        end
    end)
    updateUI_ZFD(true)
end

local function disableZFD()
    if not isZFD then return end; isZFD=false
    if zfdConn then zfdConn:Disconnect(); zfdConn=nil end
    updateUI_ZFD(false)
end

