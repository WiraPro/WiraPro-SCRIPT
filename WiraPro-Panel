-- ══════════════════════════════════════════
local function teleportToPlayer(target)
    local myChar = player.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local tChar  = target.Character
    local tRoot  = tChar  and tChar:FindFirstChild("HumanoidRootPart")
    if not myRoot or not tRoot then return end
    myRoot.CFrame = tRoot.CFrame * CFrame.new(0, 0, -3)
end

local function refreshPlayerList()
    for _, child in ipairs(tpList:GetChildren()) do
        if child.Name ~= "TpEmpty" then child:Destroy() end
    end

    local others = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then table.insert(others, p) end
    end

    tpCount.Text = #others .. " player"

    if #others == 0 then
        tpEmpty.Visible = true
        tpList.CanvasSize = UDim2.new(0,0,0,0)
        return
    end
    tpEmpty.Visible = false

    local BTN_H  = 26
    local BTN_GAP = 4
    for i, p in ipairs(others) do
        local yPos = (i-1) * (BTN_H + BTN_GAP) + 4

        local btn = Instance.new("TextButton")
        btn.Size=UDim2.new(1,-8,0,BTN_H); btn.Position=UDim2.new(0,4,0,yPos)
        btn.BackgroundColor3=Color3.fromRGB(0,110,88)
        btn.BackgroundTransparency=0.38
        btn.BorderSizePixel=0; btn.AutoButtonColor=false
        btn.TextColor3=Color3.fromRGB(200,255,240)
        btn.Text=p.Name; btn.TextSize=11
        btn.Font=Enum.Font.GothamBold
        btn.TextXAlignment=Enum.TextXAlignment.Left
        btn.ZIndex=7; btn.Parent=tpList
        Instance.new("UICorner",btn).CornerRadius=UDim.new(0,6)

        local stk=Instance.new("UIStroke",btn)
        stk.Color=Color3.fromRGB(0,200,160); stk.Thickness=1.0; stk.Transparency=0.55

        local arrow = Instance.new("TextLabel")
        arrow.Size=UDim2.new(0,18,1,0); arrow.Position=UDim2.new(1,-20,0,0)
        arrow.BackgroundTransparency=1
        arrow.Text=">"; arrow.TextColor3=Color3.fromRGB(0,200,160)
        arrow.TextSize=11; arrow.Font=Enum.Font.GothamBold
        arrow.TextXAlignment=Enum.TextXAlignment.Center
        arrow.ZIndex=8; arrow.Parent=btn

        local pad = Instance.new("UIPadding")
        pad.PaddingLeft=UDim.new(0,8); pad.Parent=btn

        btn.MouseEnter:Connect(function()
            TweenService:Create(btn,TweenInfo.new(0.10),
                {BackgroundColor3=Color3.fromRGB(0,155,120),BackgroundTransparency=0.18}):Play()
        end)
        btn.MouseLeave:Connect(function()
            TweenService:Create(btn,TweenInfo.new(0.10),
                {BackgroundColor3=Color3.fromRGB(0,110,88),BackgroundTransparency=0.38}):Play()
        end)

        local targetPlayer = p
        btn.MouseButton1Click:Connect(function()
            teleportToPlayer(targetPlayer)
            TweenService:Create(btn,TweenInfo.new(0.08),
                {BackgroundColor3=Color3.fromRGB(40,220,140),BackgroundTransparency=0.10}):Play()
            task.delay(0.35,function()
                if btn and btn.Parent then
                    TweenService:Create(btn,TweenInfo.new(0.15),
                        {BackgroundColor3=Color3.fromRGB(0,110,88),BackgroundTransparency=0.38}):Play()
                end
            end)
        end)
    end

    local totalH = #others * (BTN_H + BTN_GAP) + 8
    tpList.CanvasSize = UDim2.new(0, 0, 0, totalH)
end

