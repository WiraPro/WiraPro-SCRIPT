-- HELPER: tombol glass gelap
-- ══════════════════════════════════════════
local function makeBtn(parent, yPos, text, bgCol, accentCol, h)
    h = h or 36
    local btn = Instance.new("TextButton")
    btn.Size=UDim2.new(1,-20,0,h); btn.Position=UDim2.new(0,10,0,yPos)
    btn.BackgroundColor3=bgCol; btn.BackgroundTransparency=0.28
    btn.TextColor3=Color3.fromRGB(255,255,255); btn.Text=text
    btn.TextSize=12; btn.Font=Enum.Font.GothamBold
    btn.BorderSizePixel=0; btn.AutoButtonColor=false
    btn.ZIndex=5; btn.Parent=parent
    Instance.new("UICorner",btn).CornerRadius=UDim.new(0,9)

    local stk=Instance.new("UIStroke",btn)
    stk.Color=accentCol; stk.Thickness=1.2; stk.Transparency=0.45

    -- Kilap tipis atas tombol
    local shine=Instance.new("Frame")
    shine.Size=UDim2.new(0.55,0,0,2); shine.Position=UDim2.new(0.12,0,0,3)
    shine.BackgroundColor3=Color3.fromRGB(255,255,255)
    shine.BackgroundTransparency=0.55; shine.BorderSizePixel=0
    shine.ZIndex=6; shine.Parent=btn
    Instance.new("UICorner",shine).CornerRadius=UDim.new(1,0)

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn,TweenInfo.new(0.12),{BackgroundTransparency=0.10}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn,TweenInfo.new(0.12),{BackgroundTransparency=0.28}):Play()
    end)

    return btn, stk
end

