-- SLIDER LOGIC — FLY
-- ══════════════════════════════════════════
local isDragFly = false

local function updateFlySlider(ratio)
    ratio    = math.clamp(ratio,0,1)
    flySpeed = math.floor(FLY_MIN+(FLY_MAX-FLY_MIN)*ratio)
    flyFill.Size     = UDim2.new(ratio,0,1,0)
    flyKnob.Position = UDim2.new(ratio,-7,0.5,-7)
    flyLbl.Text      = "Kecepatan Terbang: "..flySpeed
end

local function getFlyRatio(pos)
    local tp=flyTrack.AbsolutePosition; local ts=flyTrack.AbsoluteSize
    return (pos.X-tp.X)/ts.X
end

flyKnob.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1
    or i.UserInputType==Enum.UserInputType.Touch then isDragFly=true end
end)
flyTrack.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1
    or i.UserInputType==Enum.UserInputType.Touch then
        isDragFly=true; updateFlySlider(getFlyRatio(i.Position))
    end
end)

-- ══════════════════════════════════════════
-- SLIDER LOGIC — RUN
-- ══════════════════════════════════════════
local isDragRun = false

local function updateRunSlider(ratio)
    ratio    = math.clamp(ratio,0,1)
    runSpeed = math.floor(RUN_MIN+(RUN_MAX-RUN_MIN)*ratio)
    runFill.Size     = UDim2.new(ratio,0,1,0)
    runKnob.Position = UDim2.new(ratio,-7,0.5,-7)
    runLbl.Text      = "Kecepatan Lari: "..runSpeed

    if isSpeedRun then
        local char = player.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum.WalkSpeed = runSpeed end
        end
    end
end

local function getRunRatio(pos)
    local tp=runTrack.AbsolutePosition; local ts=runTrack.AbsoluteSize
    return (pos.X-tp.X)/ts.X
end

runKnob.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1
    or i.UserInputType==Enum.UserInputType.Touch then isDragRun=true end
end)
runTrack.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1
    or i.UserInputType==Enum.UserInputType.Touch then
        isDragRun=true; updateRunSlider(getRunRatio(i.Position))
    end
end)

UserInputService.InputChanged:Connect(function(i)
    if i.UserInputType~=Enum.UserInputType.MouseMovement
    and i.UserInputType~=Enum.UserInputType.Touch then return end
    if isDragFly then updateFlySlider(getFlyRatio(i.Position)) end
    if isDragRun then updateRunSlider(getRunRatio(i.Position)) end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1
    or i.UserInputType==Enum.UserInputType.Touch then
        isDragFly=false; isDragRun=false
    end
end)

