-- ══════════════════════════════════════════
local function createESPFor(target)
    if target == player then return end
    local char = target.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local old = root:FindFirstChild("WiraESP")
    if old then old:Destroy() end

    local bb = Instance.new("BillboardGui")
    bb.Name         = "WiraESP"
    bb.Size         = UDim2.new(0, 140, 0, 22)
    bb.StudsOffset  = Vector3.new(0, 3.0, 0)
    bb.AlwaysOnTop  = true
    bb.ResetOnSpawn = false
    bb.Parent       = root

    local lbl = Instance.new("TextLabel")
    lbl.Name                   = "ESPLabel"
    lbl.Size                   = UDim2.new(1, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text                   = target.Name .. "  [-- m]"
    lbl.TextColor3             = C.AccentESP
    lbl.TextSize               = 12
    lbl.Font                   = Enum.Font.GothamBold
    lbl.TextXAlignment         = Enum.TextXAlignment.Center
    lbl.TextStrokeTransparency = 0.20
    lbl.TextStrokeColor3       = Color3.fromRGB(0, 0, 0)
    lbl.Parent                 = bb
end

local function removeESPFor(target)
    local char = target.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if root then
        local bb = root:FindFirstChild("WiraESP")
        if bb then bb:Destroy() end
    end
end

-- ══════════════════════════════════════════
-- ENABLE / DISABLE — ESP
-- ══════════════════════════════════════════
local function enableESP()
    if isESP then return end; isESP = true

    for _, p in ipairs(Players:GetPlayers()) do
        createESPFor(p)
    end

    espConn = RunService.Heartbeat:Connect(function()
        local myChar = player.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player then
                local char = p.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                if root then
                    local bb = root:FindFirstChild("WiraESP")
                    if not bb then
                        createESPFor(p)
                        bb = root:FindFirstChild("WiraESP")
                    end
                    if bb then
                        local lbl = bb:FindFirstChild("ESPLabel")
                        if lbl then
                            if myRoot then
                                local dist = math.floor(
                                    (myRoot.Position - root.Position).Magnitude
                                )
                                lbl.Text = p.Name .. "  [" .. dist .. " m]"
                            else
                                lbl.Text = p.Name .. "  [-- m]"
                            end
                        end
                    end
                end
            end
        end
    end)

    updateUI_ESP(true)
end

local function disableESP()
    if not isESP then return end; isESP = false
    if espConn then espConn:Disconnect(); espConn = nil end
    for _, p in ipairs(Players:GetPlayers()) do
        removeESPFor(p)
    end
    updateUI_ESP(false)
end

