local function uiSlider(card,lbl,mn,mx,def,yOff,fmt,onChange)
    makeLabel(card,lbl,UDim2.new(0.62,0,0,14),UDim2.new(0,8,0,yOff),10,false,CFG.CreamDim,Enum.TextXAlignment.Left)
    local vL=makeLabel(card,fmt(def),UDim2.new(0.38,-8,0,14),UDim2.new(0.62,0,0,yOff),10,true,CFG.Cream,Enum.TextXAlignment.Right)
    local trk=Instance.new("Frame"); trk.Size=UDim2.new(1,-16,0,5); trk.Position=UDim2.new(0,8,0,yOff+16)
    trk.BackgroundColor3=CFG.BgBase; trk.BackgroundTransparency=0.38; trk.BorderSizePixel=0; trk.Parent=card
    reg(trk,"BackgroundColor3","BgBase")
    local tC=Instance.new("UICorner"); tC.CornerRadius=UDim.new(1,0); tC.Parent=trk
    local tS=Instance.new("UIStroke"); tS.Color=CFG.CoralDim; tS.Thickness=1; tS.Transparency=0.48; tS.Parent=trk
    reg(tS,"Color","CoralDim")
    local fill=Instance.new("Frame"); fill.Size=UDim2.new((def-mn)/(mx-mn),0,1,0)
    fill.BackgroundColor3=CFG.Coral; fill.BackgroundTransparency=0.18; fill.BorderSizePixel=0; fill.Parent=trk
    reg(fill,"BackgroundColor3","Coral")
    local fC=Instance.new("UICorner"); fC.CornerRadius=UDim.new(1,0); fC.Parent=fill
    local knob=Instance.new("Frame"); knob.Size=UDim2.new(0,14,0,14); knob.Position=UDim2.new((def-mn)/(mx-mn),-7,0.5,-7)
    knob.BackgroundColor3=CFG.CoralGlow; knob.BackgroundTransparency=0.08; knob.BorderSizePixel=0; knob.ZIndex=6; knob.Parent=trk
    reg(knob,"BackgroundColor3","CoralGlow")
    local kC=Instance.new("UICorner"); kC.CornerRadius=UDim.new(1,0); kC.Parent=knob
    local kS=Instance.new("UIStroke"); kS.Color=Color3.fromRGB(255,255,255); kS.Thickness=1; kS.Transparency=0.52; kS.Parent=knob
    local dg=false
    local function upd(pos)
        local r=math.clamp((pos.X-trk.AbsolutePosition.X)/trk.AbsoluteSize.X,0,1)
        local v=math.floor(mn+r*(mx-mn)+0.5); local sr=(v-mn)/(mx-mn)
        fill.Size=UDim2.new(sr,0,1,0); knob.Position=UDim2.new(sr,-7,0.5,-7)
        vL.Text=fmt(v); if onChange then onChange(v) end
    end
    knob.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then dg=true end end)
    trk.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then dg=true; upd(i.Position) end end)
    UserInputService.InputChanged:Connect(function(i) if dg and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then upd(i.Position) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then dg=false end end)
end

