local function newObj(class, props, parent)
    local obj = Instance.new(class)
    for k, v in pairs(props) do obj[k] = v end
    if parent then obj.Parent = parent end
    return obj
end

local function corner(r, p) newObj("UICorner",{CornerRadius=UDim.new(0,r)},p) end
local function stroke(t, c, p) newObj("UIStroke",{Thickness=t,Color=c or COLOR.accent},p) end
local function padding(t,b,l,r,p)
    local pad = Instance.new("UIPadding")
    pad.PaddingTop    = UDim.new(0,t)
    pad.PaddingBottom = UDim.new(0,b)
    pad.PaddingLeft   = UDim.new(0,l)
    pad.PaddingRight  = UDim.new(0,r)
    pad.Parent = p
end

