    reg(tS,"Color","CoralDim")
    local fill=Instance.new("Frame"); fill.Size=UDim2.new((SP_DEF-SP_MIN)/(SP_MAX-SP_MIN),0,1,0)
    fill.BackgroundColor3=CFG.Coral; fill.BackgroundTransparency=0.18; fill.BorderSizePixel=0; fill.Parent=trk
