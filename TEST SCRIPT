local function miniSlider(lbl,mn,mx,def,yOff,onChange)
    makeLabel(orbitCard,lbl,UDim2.new(0.55,0,0,13),UDim2.new(0,8,0,yOff),9,false,CFG.CreamDim,Enum.TextXAlignment.Left)
    local vL=makeLabel(orbitCard,tostring(def),UDim2.new(0.45,-8,0,13),UDim2.new(0.55,0,0,yOff),9,true,CFG.Cream,Enum.TextXAlignment.Right)
