-- FLY RENDER LOOP
-- ══════════════════════════════════════════
RunService.RenderStepped:Connect(function(dt)
    if not flyActive or freecamActive then return end
    local char = Player.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp or not flyBodyVelocity then return end

    local camCF2   = Camera.CFrame
    local mi       = Vector3.new(0,0,0)
    -- Horizontal dari arah kamera (proyeksikan ke XZ saja)
    local fwd      = Vector3.new(camCF2.LookVector.X, 0, camCF2.LookVector.Z)
    local right    = Vector3.new(camCF2.RightVector.X, 0, camCF2.RightVector.Z)
    if fwd.Magnitude  > 0 then fwd   = fwd.Unit   end
    if right.Magnitude > 0 then right = right.Unit end

    if UserInputService:IsKeyDown(Enum.KeyCode.W) or UserInputService:IsKeyDown(Enum.KeyCode.Up)    then mi = mi + fwd   end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) or UserInputService:IsKeyDown(Enum.KeyCode.Down)  then mi = mi - fwd   end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) or UserInputService:IsKeyDown(Enum.KeyCode.Right) then mi = mi + right  end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) or UserInputService:IsKeyDown(Enum.KeyCode.Left)  then mi = mi - right  end
    if UserInputService:IsKeyDown(Enum.KeyCode.E) or UserInputService:IsKeyDown(Enum.KeyCode.Space) then mi = mi + Vector3.new(0,1,0) end
    if UserInputService:IsKeyDown(Enum.KeyCode.Q)                                                    then mi = mi - Vector3.new(0,1,0) end

    if mi.Magnitude > 0 then mi = mi.Unit end
    flyBodyVelocity.Velocity = mi * flySpeed

    -- Gyro ikut arah kamera (horizontal) supaya karakter tidak aneh
    local yawOnly = CFrame.new(hrp.Position) * CFrame.Angles(0, math.atan2(-camCF2.LookVector.X, -camCF2.LookVector.Z), 0)
    flyBodyGyro.CFrame = yawOnly
end)

-- ══════════════════════════════════════════
-- RENDER LOOP
-- ══════════════════════════════════════════
RunService.RenderStepped:Connect(function(dt)
    if not freecamActive then return end
    curFOV=curFOV+(tgtFOV-curFOV)*0.1*(dt*60)
    if mode=="free" then
        local mi=Vector3.new(0,0,0)
        if UserInputService:IsKeyDown(Enum.KeyCode.W) or UserInputService:IsKeyDown(Enum.KeyCode.Up)    then mi+=Vector3.new(0,0,-1) end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) or UserInputService:IsKeyDown(Enum.KeyCode.Down)  then mi+=Vector3.new(0,0, 1) end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) or UserInputService:IsKeyDown(Enum.KeyCode.Left)  then mi+=Vector3.new(-1,0,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) or UserInputService:IsKeyDown(Enum.KeyCode.Right) then mi+=Vector3.new( 1,0,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.E) then mi+=Vector3.new(0, 1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.Q) then mi+=Vector3.new(0,-1,0) end
        if leftActive then
            local d=leftCur-leftStart
            if d.Magnitude>8 then local n=(d-d.Unit*8).Unit; mi+=Vector3.new(n.X,0,n.Y) end
        end
        if mi.Magnitude>0 then
            local rc=CFrame.Angles(0,yaw,0)*CFrame.Angles(pitch,0,0)
            local wm=rc.LookVector*(-mi.Z)+rc.RightVector*mi.X+Vector3.new(0,1,0)*mi.Y
            if wm.Magnitude>0 then wm=wm.Unit end
            camPos=camPos+wm*CFG.MoveSpeed*(dt*60)
        end
        targetCF=CFrame.new(camPos)*CFrame.Angles(0,yaw,0)*CFrame.Angles(pitch,0,0)*CFrame.Angles(0,0,roll)
    elseif mode=="orbit" then
        local tgtPlayer=orbitTarget or Player
        if orbitTarget and not orbitTarget.Parent then
            orbitTarget=nil; orbitStatusLbl.Text="Diri sendiri"; tgtPlayer=Player
        end
        local targetPos=Vector3.new(0,0,0)
        if tgtPlayer and tgtPlayer.Character then
            local root=tgtPlayer.Character:FindFirstChild("HumanoidRootPart")
            if root then targetPos=root.Position end
        end
        orbitAngle=orbitAngle+CFG.OrbitSpeed*dt
        local ox=math.sin(orbitAngle)*CFG.OrbitRadius; local oz=math.cos(orbitAngle)*CFG.OrbitRadius
        local newPos=targetPos+Vector3.new(ox,CFG.OrbitHeight,oz)
        targetCF=CFrame.new(newPos,targetPos+Vector3.new(0,1,0)); camPos=newPos
    end
    camCF=camCF:Lerp(targetCF,CFG.SmoothFactor*(dt*60))
    Camera.CFrame=camCF; Camera.FieldOfView=math.clamp(curFOV,CFG.MinFOV,CFG.MaxFOV)
end)

