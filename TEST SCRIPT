-- UI PERSISTENCE PROTECTION
-- ══════════════════════════════════════════
local function enforceUIVisibility()
    if not ScreenGui or not ScreenGui.Parent then
        ScreenGui=Instance.new("ScreenGui")
        ScreenGui.Name="WiraProFreecam"; ScreenGui.ResetOnSpawn=false
        ScreenGui.DisplayOrder=999; ScreenGui.ZIndexBehavior=Enum.ZIndexBehavior.Sibling
        ScreenGui.Parent=PlayerGui
    end
    ScreenGui.Enabled=true
end
ScreenGui:GetPropertyChangedSignal("Enabled"):Connect(function()
    if not ScreenGui.Enabled then task.defer(function() ScreenGui.Enabled=true end) end
end)
ScreenGui:GetPropertyChangedSignal("Parent"):Connect(function()
    if ScreenGui.Parent~=PlayerGui then
        task.defer(function() pcall(function() ScreenGui.Parent=PlayerGui end) end)
    end
end)
PlayerGui.ChildRemoved:Connect(function(child)
    if child.Name=="WiraProFreecam" then task.defer(enforceUIVisibility) end
end)
task.spawn(function()
    while true do task.wait(1); pcall(enforceUIVisibility) end
end)
PlayerGui.DescendantAdded:Connect(function(obj)
    if obj:IsA("LocalScript") or obj:IsA("Script") then
        task.defer(function()
            if ScreenGui then pcall(function() ScreenGui.Enabled=true end) end
        end)
    end
end)

