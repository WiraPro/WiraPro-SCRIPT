local function enableFly()
    if freecamActive then return end  -- jangan fly saat freecam aktif
    local char = Player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local h   = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not h then return end

    flyActive = true
    h.PlatformStand = true

    -- Hapus lama jika ada
    if flyBodyVelocity then flyBodyVelocity:Destroy() end
    if flyBodyGyro     then flyBodyGyro:Destroy()     end

    flyBodyVelocity = Instance.new("BodyVelocity")
    flyBodyVelocity.Velocity  = Vector3.new(0,0,0)
    flyBodyVelocity.MaxForce  = Vector3.new(1e5,1e5,1e5)
    flyBodyVelocity.P         = 1e4
    flyBodyVelocity.Parent    = hrp

    flyBodyGyro = Instance.new("BodyGyro")
    flyBodyGyro.MaxTorque = Vector3.new(1e5,1e5,1e5)
    flyBodyGyro.P         = 1e4
    flyBodyGyro.CFrame    = hrp.CFrame
    flyBodyGyro.Parent    = hrp

    flyToggleLbl.Text="FLY  ON"; flyToggleLbl.TextColor3=CFG.CoralGlow
    flyToggleSub.TextColor3=CFG.CoralGlow
    TweenService:Create(flyLED,TweenInfo.new(0.18),{BackgroundColor3=CFG.Coral}):Play()
    TweenService:Create(flyCard,TweenInfo.new(0.18),{BackgroundColor3=Color3.fromRGB(20,10,0)}):Play()
end

local function disableFly()
    flyActive = false
    if flyBodyVelocity then flyBodyVelocity:Destroy(); flyBodyVelocity=nil end
    if flyBodyGyro     then flyBodyGyro:Destroy();     flyBodyGyro=nil     end
    local char = Player.Character
    if char then
        local h = char:FindFirstChildOfClass("Humanoid")
        if h then h.PlatformStand=false; h.WalkSpeed=runSpeedValue end
    end
    flyToggleLbl.Text="FLY  OFF"; flyToggleLbl.TextColor3=CFG.CreamDim
    flyToggleSub.TextColor3=CFG.CreamDim
    TweenService:Create(flyLED,TweenInfo.new(0.18),{BackgroundColor3=Color3.fromRGB(45,25,0)}):Play()
    TweenService:Create(flyCard,TweenInfo.new(0.18),{BackgroundColor3=CFG.BgCard}):Play()
end

