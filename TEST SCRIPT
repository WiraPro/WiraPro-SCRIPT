--         KEYBOARD SHORTCUTS (PC)
-- ══════════════════════════════════════
UserInputService.InputBegan:Connect(function(inp, gpe)
    if gpe then return end
    if inp.KeyCode == Enum.KeyCode.F then
        -- Toggle fly with F key
        Settings.flyEnabled = not Settings.flyEnabled
        setFlyToggle(Settings.flyEnabled)
        if Settings.flyEnabled then startFly() else stopFly() end
    end
    if inp.KeyCode == Enum.KeyCode.J then
        -- Toggle inf jump with J key
        Settings.jumpEnabled = not Settings.jumpEnabled
        setJumpToggle(Settings.jumpEnabled)
        if Settings.jumpEnabled then startInfJump() else stopInfJump() end
    end
end)

