local function findOrbitTarget(input)
    input=tostring(input):match("^%s*(.-)%s*$")
    if input=="" then feedbackLbl.Text="⚠ Input kosong"; feedbackLbl.TextColor3=Color3.fromRGB(255,200,80); return end
    local asNum=tonumber(input); local found=nil
    if asNum then
        for _,p in ipairs(Players:GetPlayers()) do if p.UserId==asNum then found=p; break end end
        if not found then feedbackLbl.Text="✕ UserId "..asNum.." tidak ada"; feedbackLbl.TextColor3=Color3.fromRGB(255,100,60); return end
    else
        for _,p in ipairs(Players:GetPlayers()) do if p.Name:lower()==input:lower() then found=p; break end end
        if not found then feedbackLbl.Text="✕ \""..input.."\" tidak ditemukan"; feedbackLbl.TextColor3=Color3.fromRGB(255,100,60); return end
    end
    if not found.Character or not found.Character:FindFirstChild("HumanoidRootPart") then
        feedbackLbl.Text="⚠ Karakter "..found.Name.." belum spawn"; feedbackLbl.TextColor3=Color3.fromRGB(255,200,80); return
    end
    orbitTarget=found; orbitStatusLbl.Text=found.Name
    feedbackLbl.Text="✓ "..found.Name.." ["..found.UserId.."]"; feedbackLbl.TextColor3=CFG.CoralGlow
    local root=found.Character:FindFirstChild("HumanoidRootPart")
    if root then orbitAngle=math.atan2(camPos.X-root.Position.X,camPos.Z-root.Position.Z) end
end
SearchBtn.MouseButton1Click:Connect(function() findOrbitTarget(InputBox.Text) end)
