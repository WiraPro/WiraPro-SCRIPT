Player.CharacterAdded:Connect(function(char)
    -- Reset fly body objects (sudah di-destroy saat karakter lama removed)
    flyBodyVelocity = nil; flyBodyGyro = nil
    if flyActive then
        -- Karakter baru: pasang kembali fly setelah sedikit delay
