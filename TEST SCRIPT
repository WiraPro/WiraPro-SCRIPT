local function teleportToPlayer(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then
        feedbackLbl.Text="⚠ Karakter tidak ditemukan"; feedbackLbl.TextColor3=Color3.fromRGB(255,200,80); return
    end
    local root=targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then feedbackLbl.Text="⚠ HumanoidRootPart tidak ada"; feedbackLbl.TextColor3=Color3.fromRGB(255,200,80); return end
    local myChar=Player.Character
    if not myChar then feedbackLbl.Text="⚠ Karakter kamu tidak ada"; feedbackLbl.TextColor3=Color3.fromRGB(255,200,80); return end
    local myRoot=myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then feedbackLbl.Text="⚠ HumanoidRootPart kamu tidak ada"; feedbackLbl.TextColor3=Color3.fromRGB(255,200,80); return end
    myRoot.CFrame=root.CFrame+Vector3.new(3,0,0)
    feedbackLbl.Text="✓ Teleport ke "..targetPlayer.Name; feedbackLbl.TextColor3=CFG.CoralGlow
end

