local STUD_TO_METER=0.28
RunService.RenderStepped:Connect(function()
    if not espActive then return end
    local myPos
    if freecamActive then myPos=Camera.CFrame.Position
    else
        local myChar=Player.Character
        local myRoot=myChar and myChar:FindFirstChild("HumanoidRootPart")
        myPos=myRoot and myRoot.Position or Camera.CFrame.Position
    end
    for p,data in pairs(espLabels) do
        if not p or not p.Parent then removeEspLabel(p); continue end
        local char=p.Character
        local root=char and char:FindFirstChild("HumanoidRootPart")
        if not root then data.nameLbl.Visible=false; data.distLbl.Visible=false; continue end
        local headPos=root.Position+Vector3.new(0,2.8,0)
        local screenPos,onScreen=Camera:WorldToViewportPoint(headPos)
        if not onScreen or screenPos.Z<=0 then data.nameLbl.Visible=false; data.distLbl.Visible=false; continue end
        data.nameLbl.Visible=true; data.distLbl.Visible=true
        data.nameLbl.Position=UDim2.new(0,screenPos.X,0,screenPos.Y)
        data.distLbl.Position=UDim2.new(0,screenPos.X,0,screenPos.Y+1)
        local studs=(myPos-root.Position).Magnitude
        local meters=studs*STUD_TO_METER
        local distStr
        if meters>=1000 then distStr=string.format("%.1f km",meters/1000)
        elseif meters>=1 then distStr=string.format("%.1f m",meters)
        else distStr=string.format("%.2f m",meters) end
        data.distLbl.Text=distStr
        if meters<=8 then data.nameLbl.TextColor3=Color3.fromRGB(255,100,100)
        elseif meters<=22 then data.nameLbl.TextColor3=CFG.CoralGlow
        else data.nameLbl.TextColor3=CFG.Cream end
    end
end)

