-- ══════════════════════════════════════
--         FLY LOGIC
-- ══════════════════════════════════════
function startFly()
    local char = player.Character
    if not char then return end
    local hum  = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not hum or not root then return end

    hum.PlatformStand = true

    local bv = Instance.new("BodyVelocity")
    bv.Velocity        = Vector3.new(0,0,0)
    bv.MaxForce        = Vector3.new(1e5,1e5,1e5)
    bv.P               = 1e4
    bv.Parent          = root

    local bg = Instance.new("BodyGyro")
    bg.MaxTorque       = Vector3.new(1e5,1e5,1e5)
    bg.P               = 1e4
    bg.D               = 500
    bg.CFrame          = root.CFrame
    bg.Parent          = root

    flyConnection = RunService.Heartbeat:Connect(function()
        if not Settings.flyEnabled then return end
        local camCF = camera.CFrame
        local dir   = Vector3.new(0,0,0)

        -- WASD / Left stick movement mapped onto camera
        local moveDir = Vector3.new(0,0,0)
        if hum.MoveDirection.Magnitude > 0 then
            local flat = Vector3.new(hum.MoveDirection.X, 0, hum.MoveDirection.Z).Unit
            local camRight   = camCF.RightVector
            local camForward = -camCF.LookVector
            local projRight  = Vector3.new(camRight.X,0,camRight.Z).Unit
            local projFwd    = Vector3.new(camForward.X,0,camForward.Z).Unit
            -- use camera-relative direction (horizontal)
            local vert = camCF.LookVector
            -- full 3D fly based on camera look direction
            local look = camCF.LookVector
            moveDir = look * hum.MoveDirection.Z + camRight * hum.MoveDirection.X
        end

        -- vertical from keys / buttons
        local upDown = 0
        if UserInputService:IsKeyDown(flyKeys.up) or isTouching.up then
            upDown = 1
        elseif UserInputService:IsKeyDown(flyKeys.down) or isTouching.down then
            upDown = -1
        end

        dir = (moveDir + Vector3.new(0, upDown, 0))
        if dir.Magnitude > 1 then dir = dir.Unit end

        bv.Velocity = dir * Settings.flySpeed
        bg.CFrame   = camCF
    end)
end

function stopFly()
    if flyConnection then
        flyConnection:Disconnect()
        flyConnection = nil
    end
    local char = player.Character
    if not char then return end
    local hum  = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if hum then hum.PlatformStand = false end
    if root then
        local bv = root:FindFirstChildOfClass("BodyVelocity")
        local bg = root:FindFirstChildOfClass("BodyGyro")
        if bv then bv:Destroy() end
        if bg then bg:Destroy() end
    end
end

-- ══════════════════════════════════════
--         INFINITY JUMP LOGIC
-- ══════════════════════════════════════
function startInfJump()
    if jumpConnection then jumpConnection:Disconnect() end
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    jumpConnection = hum:GetPropertyChangedSignal("Jump"):Connect(function()
        if Settings.jumpEnabled and hum.Jump then
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end)
end

function stopInfJump()
    if jumpConnection then
        jumpConnection:Disconnect()
        jumpConnection = nil
    end
end

-- ══════════════════════════════════════
--         WALKSPEED APPLY ON SPAWN
-- ══════════════════════════════════════
player.CharacterAdded:Connect(function(char)
    local hum = char:WaitForChild("Humanoid")
    hum.WalkSpeed = Settings.walkSpeed
    -- re-bind infinity jump on respawn
    if Settings.jumpEnabled then
        task.wait(0.1)
        startInfJump()
    end
    -- re-start fly if was on (optional: auto-disable on death)
    Settings.flyEnabled = false
    setFlyToggle(false)
end)

