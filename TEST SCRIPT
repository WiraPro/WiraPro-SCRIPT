local function makeGridLine(isVertical, offset, thickness, col, alpha)
    local line = Instance.new("Frame")
    if isVertical then
        line.Size     = UDim2.new(0, thickness, 1, 0)
        line.Position = UDim2.new(offset, -math.floor(thickness/2), 0, 0)
        line.AnchorPoint = Vector2.new(0, 0)
    else
        line.Size     = UDim2.new(1, 0, 0, thickness)
        line.Position = UDim2.new(0, 0, offset, -math.floor(thickness/2))
        line.AnchorPoint = Vector2.new(0, 0)
    end
    line.BackgroundColor3    = col
    line.BackgroundTransparency = alpha
    line.BorderSizePixel     = 0
    line.ZIndex              = 5
    line.Parent              = gridContainer
    return line
end

