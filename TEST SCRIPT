local function makeGlass(parent,size,pos,name,radius,alpha)
    radius=radius or UDim.new(0,16); alpha=alpha or 0.62
    local f=Instance.new("Frame"); f.Name=name or "Glass"; f.Size=size
    f.Position=pos or UDim2.new(0,0,0,0); f.BackgroundColor3=CFG.BgBase
    f.BackgroundTransparency=alpha; f.BorderSizePixel=0; f.Parent=parent
    reg(f,"BackgroundColor3","BgBase")
    local c=Instance.new("UICorner"); c.CornerRadius=radius; c.Parent=f
    local s=Instance.new("UIStroke"); s.Color=CFG.Coral; s.Thickness=1.2; s.Transparency=0.28; s.Parent=f
    reg(s,"Color","Coral")
    local sh=Instance.new("Frame"); sh.Size=UDim2.new(0.50,0,0,1.5); sh.Position=UDim2.new(0.12,0,0,7)
    sh.BackgroundColor3=CFG.CoralGlow; sh.BackgroundTransparency=0.32; sh.BorderSizePixel=0; sh.ZIndex=f.ZIndex+2; sh.Parent=f
    reg(sh,"BackgroundColor3","CoralGlow")
    Instance.new("UICorner").CornerRadius=UDim.new(1,0); (function() local cc=Instance.new("UICorner"); cc.CornerRadius=UDim.new(1,0); cc.Parent=sh end)()
    local t=Instance.new("Frame"); t.Size=UDim2.new(1,0,1,0); t.BackgroundColor3=CFG.Coral
    t.BackgroundTransparency=0.92; t.BorderSizePixel=0; t.ZIndex=f.ZIndex; t.Parent=f
    reg(t,"BackgroundColor3","Coral")
    Instance.new("UICorner").Parent=t; (function() local cc=Instance.new("UICorner"); cc.CornerRadius=radius; cc.Parent=t end)()
    return f
end

local function makeLabel(parent,text,size,pos,fs,bold,col,ax)
    local l=Instance.new("TextLabel"); l.Size=size; l.Position=pos or UDim2.new(0,0,0,0)
    l.BackgroundTransparency=1; l.Text=text; l.TextColor3=col or CFG.Cream
    l.TextSize=fs or 13; l.Font=bold and Enum.Font.MontserratBold or Enum.Font.Montserrat
    l.TextXAlignment=ax or Enum.TextXAlignment.Center; l.Parent=parent
    -- Daftarkan hanya jika warnanya adalah salah satu warna CFG (bukan warna custom/warning)
    local colorKeyMap = {
        [CFG.Cream]="Cream", [CFG.CreamDim]="CreamDim",
        [CFG.Coral]="Coral", [CFG.CoralGlow]="CoralGlow",
        [CFG.CoralDim]="CoralDim", [CFG.OnCoral]="OnCoral",
        [CFG.BgBase]="BgBase", [CFG.BgCard]="BgCard",
    }
    -- Simpan key berdasarkan warna yang dipilih saat pembuatan
    local chosenCol = col or CFG.Cream
    local foundKey = nil
    for cfgCol, k in pairs(colorKeyMap) do
        if chosenCol == cfgCol then foundKey = k; break end
    end
    if foundKey then reg(l,"TextColor3",foundKey) end
    return l
end

