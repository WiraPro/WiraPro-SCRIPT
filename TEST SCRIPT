--         RESET FUNCTION
-- ══════════════════════════════════════
local function resetAll()
    -- stop fly
    Settings.flyEnabled = false
    stopFly()
    setFlyToggle(false)

    -- stop jump
    Settings.jumpEnabled = false
    stopInfJump()
    setJumpToggle(false)

    -- speeds
    Settings.flySpeed  = DEFAULT.flySpeed
    Settings.walkSpeed = DEFAULT.walkSpeed
    setFlySpeed(DEFAULT.flySpeed)
    setWalkSpeed(DEFAULT.walkSpeed)

    -- apply walkspeed
    local char = player.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.WalkSpeed = DEFAULT.walkSpeed end
    end

    -- UI
    Settings.uiScale   = DEFAULT.uiScale
    Settings.uiOpacity = DEFAULT.uiOpacity
    setUIScale(DEFAULT.uiScale)
    setUIOpacity(DEFAULT.uiOpacity)

    local w = math.floor(BASE_W * DEFAULT.uiScale)
    local h = math.floor(BASE_H * DEFAULT.uiScale)
    mainFrame.Size = UDim2.new(0,w,0,h)
    mainFrame.BackgroundTransparency = 1 - DEFAULT.uiOpacity
end

resetBtn.MouseButton1Click:Connect(resetAll)

