--         HELPER: Slider
-- ══════════════════════════════════════
local function makeSlider(labelText, minVal, maxVal, defaultVal, suffix, order, onChanged)
    local card = newObj("Frame",{
        Size=UDim2.new(1,0,0,68),
        BackgroundColor3=COLOR.panel,
        BorderSizePixel=0,
        LayoutOrder=order,
    },contentFrame)
    corner(12,card)

    local lbl = newObj("TextLabel",{
        Size=UDim2.new(1,-70,0,20),
        Position=UDim2.new(0,12,0,8),
        BackgroundTransparency=1,
        Text=labelText,
        Font=Enum.Font.GothamSemibold,
        TextSize=12,
        TextColor3=COLOR.text,
        TextXAlignment=Enum.TextXAlignment.Left,
    },card)

    local valLbl = newObj("TextLabel",{
        Size=UDim2.new(0,60,0,20),
        Position=UDim2.new(1,-68,0,8),
        BackgroundTransparency=1,
        Text=tostring(defaultVal)..(suffix or ""),
        Font=Enum.Font.GothamBold,
        TextSize=12,
        TextColor3=COLOR.accent,
        TextXAlignment=Enum.TextXAlignment.Right,
    },card)

    local track = newObj("Frame",{
        Size=UDim2.new(1,-24,0,6),
        Position=UDim2.new(0,12,0,38),
        BackgroundColor3=Color3.fromRGB(210,210,220),
        BorderSizePixel=0,
    },card)
    corner(3,track)

    local fill = newObj("Frame",{
        Size=UDim2.new((defaultVal-minVal)/(maxVal-minVal),0,1,0),
        BackgroundColor3=COLOR.accent,
        BorderSizePixel=0,
    },track)
    corner(3,fill)

    local thumb = newObj("Frame",{
        Size=UDim2.new(0,16,0,16),
        Position=UDim2.new((defaultVal-minVal)/(maxVal-minVal),0-8,0.5,-8),
        BackgroundColor3=COLOR.white,
        BorderSizePixel=0,
    },track)
    corner(8,thumb)
    stroke(2,COLOR.accent,thumb)

    local currentVal = defaultVal
    local dragging = false

    local function setVal(v)
        v = math.clamp(math.floor(v*10+0.5)/10, minVal, maxVal)
        -- round to integer if suffix is not %
        if suffix ~= "%" then v = math.floor(v+0.5) end
        currentVal = v
        local pct = (v-minVal)/(maxVal-minVal)
        fill.Size = UDim2.new(pct,0,1,0)
        thumb.Position = UDim2.new(pct,0-8,0.5,-8)
        -- display
        if suffix == "%" then
            valLbl.Text = string.format("%.0f%%", v*100)
        else
            valLbl.Text = tostring(v)..(suffix or "")
        end
        if onChanged then onChanged(v) end
    end

    local function getValFromInput(inputPos)
        local trackPos = track.AbsolutePosition
        local trackSz  = track.AbsoluteSize
        local rel = (inputPos.X - trackPos.X) / trackSz.X
        return minVal + math.clamp(rel,0,1)*(maxVal-minVal)
    end

    thumb.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch or
           inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
        end
    end)

    track.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch or
           inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            setVal(getValFromInput(inp.Position))
        end
    end)

    UserInputService.InputChanged:Connect(function(inp)
        if dragging and (inp.UserInputType == Enum.UserInputType.Touch or
                         inp.UserInputType == Enum.UserInputType.MouseButton1) then
            setVal(getValFromInput(inp.Position))
        end
    end)

    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch or
           inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    return card, setVal, function() return currentVal end
end

