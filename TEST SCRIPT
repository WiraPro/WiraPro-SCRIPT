-- ══════════════════════════════════════════
-- COLOR REGISTRY  ← FIX UTAMA
-- Setiap elemen UI mendaftar saat dibuat.
-- applyTheme() langsung set tanpa komparasi.
-- ══════════════════════════════════════════
local colorRegistry = {}
-- entry = { obj=Instance, prop="BackgroundColor3"|"TextColor3"|etc., key="Coral"|... }

local function reg(obj, prop, key)
    table.insert(colorRegistry, { obj=obj, prop=prop, key=key })
end

local function applyTheme(theme)
    -- Update CFG dulu
    local keys = {"BgBase","BgCard","Coral","CoralLight","CoralDim","CoralGlow","Cream","CreamDim","OnCoral"}
    for _,k in ipairs(keys) do CFG[k] = theme[k] end
    activeThemeId = theme.id
    -- Terapkan ke semua elemen terdaftar
    for _,entry in ipairs(colorRegistry) do
        if entry.obj and entry.obj.Parent then
            pcall(function()
                entry.obj[entry.prop] = theme[entry.key]
            end)
        end
    end
end

