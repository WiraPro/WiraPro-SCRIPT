        Size=UDim2.new(0,36,0,36),
        Position=UDim2.new(0,8,0.5,-18),
        BackgroundTransparency=1,
        Text=iconOff,
        Font=Enum.Font.GothamBold,
        TextSize=20,
        TextColor3=COLOR.accentOff,
    },card)

    local lbl = newObj("TextLabel",{
        Size=UDim2.new(1,-110,0,20),
        Position=UDim2.new(0,50,0.5,-10),
        BackgroundTransparency=1,
        Text=labelText,
        Font=Enum.Font.GothamSemibold,
        TextSize=13,
        TextColor3=COLOR.text,
        TextXAlignment=Enum.TextXAlignment.Left,
    },card)

    local statusLbl = newObj("TextLabel",{
        Size=UDim2.new(1,-110,0,16),
        Position=UDim2.new(0,50,0.5,8),
        BackgroundTransparency=1,
        Text="OFF",
        Font=Enum.Font.Gotham,
        TextSize=10,
        TextColor3=COLOR.accentOff,
        TextXAlignment=Enum.TextXAlignment.Left,
    },card)

    -- pill toggle
    local pillBg = newObj("Frame",{
        Size=UDim2.new(0,50,0,26),
        Position=UDim2.new(1,-62,0.5,-13),
        BackgroundColor3=COLOR.accentOff,
        BorderSizePixel=0,
    },card)
    corner(13,pillBg)

    local pill = newObj("Frame",{
        Size=UDim2.new(0,20,0,20),
        Position=UDim2.new(0,3,0,3),
        BackgroundColor3=COLOR.white,
        BorderSizePixel=0,
    },pillBg)
    corner(10,pill)

    local btn = newObj("TextButton",{
        Size=UDim2.new(1,0,1,0),
        BackgroundTransparency=1,
        Text="",
    },card)

    local state = false
    local function refresh(s)
        state = s
        local tween = TweenService:Create
        if state then
            TweenService:Create(pillBg,TweenInfo.new(0.2),{BackgroundColor3=colorOn}):Play()
            TweenService:Create(pill,TweenInfo.new(0.2),{Position=UDim2.new(0,27,0,3)}):Play()
            icon.Text = iconOn
            icon.TextColor3 = colorOn
            statusLbl.Text = "ON"
            statusLbl.TextColor3 = colorOn
        else
            TweenService:Create(pillBg,TweenInfo.new(0.2),{BackgroundColor3=COLOR.accentOff}):Play()
            TweenService:Create(pill,TweenInfo.new(0.2),{Position=UDim2.new(0,3,0,3)}):Play()
            icon.Text = iconOff
            icon.TextColor3 = COLOR.accentOff
            statusLbl.Text = "OFF"
            statusLbl.TextColor3 = COLOR.accentOff
        end
        if onToggle then onToggle(state) end
    end

    btn.MouseButton1Click:Connect(function()
        refresh(not state)
    end)

    return card, function(s) refresh(s) end, function() return state end
end

